generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Industry {
  KFZ
  GALA_BAU
  MONTAGE
  REINIGUNG
  SHK
  ELEKTRO
  HAUSMEISTER
  SONSTIGE
}

enum UserRole {
  OWNER
  EMPLOYEE
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum DocumentationType {
  VEHICLE_INTAKE
  ADDITIONAL_WORK
  DAMAGE_FOUND
  AFTER_DOCUMENTATION
  OTHER
}

enum ApprovalStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model Company {
  id        String   @id @default(cuid())
  name      String
  industry  Industry @default(KFZ)
  phone     String?
  email     String?
  address   String?
  logoUrl   String?

  users     User[]
  customers Customer[]
  jobs      Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(OWNER)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name      String
  phone     String?
  email     String?

  jobs      Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Job {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  title       String
  status      JobStatus @default(OPEN)

  licensePlate String?
  vehicle      String?
  mileage      Int?
  notes        String?

  items       DocumentationItem[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([customerId])
}

model DocumentationItem {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  type        DocumentationType
  title       String
  description String
  priceCents  Int?
  priceText   String?
  approvalRequired Boolean      @default(false)
  status      ApprovalStatus    @default(DRAFT)

  approval    Approval?
  photos      Photo[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([jobId])
}

model Photo {
  id                  String            @id @default(cuid())
  documentationItemId String
  documentationItem   DocumentationItem @relation(fields: [documentationItemId], references: [id], onDelete: Cascade)

  fileUrl             String
  fileName            String?
  mimeType            String?

  createdAt           DateTime @default(now())

  @@index([documentationItemId])
}

model Approval {
  id                  String            @id @default(cuid())
  documentationItemId String            @unique
  documentationItem   DocumentationItem @relation(fields: [documentationItemId], references: [id], onDelete: Cascade)

  token               String            @unique
  status              ApprovalStatus    @default(PENDING)

  approvedAt          DateTime?
  rejectedAt          DateTime?
  customerComment     String?

  customerName        String?
  ipHash              String?
  userAgent           String?
  pdfUrl              String?

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}
